---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Writing — Steven Nguyen" description="Thoughts on AI, neuroscience, and building things.">
  <section style="padding: clamp(8rem, 12vh, 12rem) 30px clamp(4rem, 8vh, 8rem);">
    <div style="max-width: 700px;">
      <div class="js-in" style="margin-bottom: clamp(3rem, 5vw, 5rem);">
        <h1 class="display display--2">Thoughts &<br/>Technical Notes</h1>
      </div>

      <div class="js-in">
        {posts.map((post, i) => (
          <a href={`/writing/${post.id}`} style="display: block; padding: 1.5rem 0; border-top: 1px solid var(--border); text-decoration: none; transition: all 0.3s;">
            <div style="display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; margin-bottom: 0.5rem;">
              <h2 class="lead" style="font-size: 13px; font-weight: 700; color: var(--text);">
                {post.data.title}
              </h2>
              <time class="lead" style="font-size: 11px; color: var(--grey); flex-shrink: 0;">
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
              </time>
            </div>
            <p class="lead" style="font-size: 12px; text-transform: none; color: var(--text-2); line-height: 1.6;">
              {post.data.description}
            </p>
            {post.data.tags && (
              <div style="display: flex; gap: 1em; margin-top: 0.5rem;">
                {post.data.tags.map((tag: string) => (
                  <span class="lead" style="font-size: 10px; color: var(--grey);">{tag}</span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="site-footer__outro">
      <div>
        <div>
          <a href="https://github.com/quakeob" class="site-footer__social" target="_blank">GH</a>
          <a href="https://x.com/Jak3dev" class="site-footer__social" target="_blank">X</a>
          <a href="https://instagram.com/stevennguye.n" class="site-footer__social" target="_blank">IG</a>
        </div>
      </div>
      <div style="text-align: center;">
        <span class="site-footer__email">stevenn348@gmail.com</span>
      </div>
      <div style="text-align: right;">
        <div>
          <a href="https://astro.build" class="site-footer__social" target="_blank">Astro</a>
        </div>
      </div>
    </div>
  </footer>
</BaseLayout>

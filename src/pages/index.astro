  <script is:inline>
    // ═══════════ HERO SLIDESHOW — always cycling, faster on scroll ═══════════
    (function() {
      const imgs = document.querySelectorAll('.hero-slideshow__img');
      if (!imgs.length) return;
      let current = 0;
      let lastScroll = 0;
      let scrollCycleAcc = 0;
      const pixelsPerCycle = 18;

      function next() {
        imgs[current].classList.remove('is-active');
        current = (current + 1) % imgs.length;
        imgs[current].classList.add('is-active');
      }

      // Baseline auto-cycle
      setInterval(next, 500);

      // Also cycle rapidly on scroll
      window.addEventListener('scroll', () => {
        const delta = Math.abs(window.scrollY - lastScroll);
        lastScroll = window.scrollY;
        scrollCycleAcc += delta;
        while (scrollCycleAcc >= pixelsPerCycle) {
          scrollCycleAcc -= pixelsPerCycle;
          next();
        }
      });
    })();

    // ═══════════ BUILD WORD + VISUAL CYCLE ═══════════
    (function() {
      const wordEl = document.getElementById('build-word');

              clearInterval(barInt);
              bootIndex++;
              setTimeout(bootSequence, 200);
            }
          }, 40);
          return;
        } else if (bl.cls === 'boot-agent') {
          // Show agent name with spinner, then resolve
          const el = document.createElement('div');
          el.className = 'agent-terminal__line agent-terminal__line--boot-agent';
          const spinChars = ['⠋','⠙','⠹','⠸','⠼','⠴','⠦','⠧','⠇','⠏'];
          let si = 0;
          const sp = document.createElement('span');
          sp.className = 'term-spinner';
          sp.textContent = spinChars[0];
          el.appendChild(sp);
          el.appendChild(document.createTextNode(' ' + bl.text));
          body.appendChild(el);
          if (body.children.length > maxLines) body.removeChild(body.firstChild);
          const spinInt = setInterval(() => { si=(si+1)%spinChars.length; sp.textContent=spinChars[si]; }, 60);
          setTimeout(() => {
            clearInterval(spinInt);
            el.innerHTML = '<span class="term-check">✓</span> ' + bl.text;
            el.classList.add('agent-terminal__line--resolved');
            bootIndex++;
            setTimeout(bootSequence, 150);
          }, bl.delay || 300);
        } else {
          renderLine(bl);
          bootIndex++;
          setTimeout(bootSequence, bl.cls === 'boot-title' ? 200 : 100);
        }
      }

      const tokensEl = document.getElementById('term-tokens');
      const ctxFill = document.getElementById('term-ctx-fill');
      const ctxPct = document.getElementById('term-ctx-pct');
      let tokenCount = 0;
      const maxCtx = 200000;

      function updateStats() {
        const add = Math.floor(800 + Math.random() * 2400);
        tokenCount = Math.min(tokenCount + add, maxCtx);
        const pct = Math.round((tokenCount / maxCtx) * 100);
        if (tokensEl) tokensEl.textContent = tokenCount.toLocaleString() + ' tokens';
        if (ctxFill) ctxFill.style.width = pct + '%';
        if (ctxPct) ctxPct.textContent = pct + '%';
        // Reset at ~85% to simulate new conversation
        if (pct > 85) tokenCount = Math.floor(Math.random() * 8000);
      }

      function addLine() {
        // Remove previous thinking indicator
        const prev = body.querySelector('.term-thinking');
        if (prev) prev.remove();

        renderLine(lines[i % lines.length]);
        i++;
        updateStats();

        // Add thinking indicator
        const thinking = document.createElement('div');
        thinking.className = 'agent-terminal__line term-thinking';
        thinking.innerHTML = '<span class="term-dots"><span>·</span><span>·</span><span>·</span></span>';
        body.appendChild(thinking);
        if (body.children.length > maxLines) body.removeChild(body.firstChild);

        setTimeout(addLine, speed + Math.random() * (speed * 0.6));
      }

      // Start boot when terminal scrolls into view
      const termEl = document.getElementById('agent-terminal');
      const termObs = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) {
          termObs.disconnect();
          setTimeout(bootSequence, 400);
        }
      }, { threshold: 0.3 });
      termObs.observe(termEl);

      // Speed up on scroll, ease back gradually
      let scrollTimeout;
      let easeInterval;
      window.addEventListener('scroll', () => {
        speed = 80;
        clearTimeout(scrollTimeout);
        clearInterval(easeInterval);
        scrollTimeout = setTimeout(() => {
          easeInterval = setInterval(() => {
            speed = Math.min(speed + 50, 500);
            if (speed >= 500) clearInterval(easeInterval);
          }, 150);
        }, 300);
      });
    })();

    // ═══════════ WIDGET PREVIEW ANIMATION ═══════════
    (function() {
      const card = document.querySelector('.has-preview');
      if (!card) return;

      const totalEl = document.getElementById('widget-total');
      const todayEl = document.getElementById('widget-today');
      const costEl = document.getElementById('widget-cost');
      const barsEl = document.getElementById('widget-bars');
      const labelEl = document.getElementById('widget-chart-label');

      let total = 14.2, today = 847.3, cost = 142.80;
      let tickInt;

      function fmt(n) { return n >= 1000 ? (n/1000).toFixed(1) + 'M' : n.toFixed(1) + 'K'; }

      const chartViews = [
        {
          label: 'Hourly',
          bars: [
            { h: 20, l: '6a' }, { h: 45, l: '8a' }, { h: 78, l: '10a' },
            { h: 55, l: '12p' }, { h: 30, l: '2p' }, { h: 65, l: '4p' },
            { h: 88, l: '6p' }, { h: 72, l: '8p' }, { h: 40, l: '10p' },
          ],
          peak: 6, today: null,
        },
        {
          label: '7-day',
          bars: [
            { h: 35, l: 'M' }, { h: 62, l: 'T' }, { h: 48, l: 'W' },
            { h: 85, l: 'T' }, { h: 71, l: 'F' }, { h: 40, l: 'S' },
            { h: 55, l: 'S' },
          ],
          peak: 3, today: 6,
        },
        {
          label: 'Monthly',
          bars: [
            { h: 30, l: 'Sep' }, { h: 52, l: 'Oct' }, { h: 68, l: 'Nov' },
            { h: 45, l: 'Dec' }, { h: 74, l: 'Jan' }, { h: 90, l: 'Feb' },
            { h: 58, l: 'Mar' },
          ],
          peak: 5, today: 6,
        },
      ];

      let viewIndex = 0;
      let cycleInt;

      function renderBars(view) {
        // Fade out
        barsEl.style.opacity = '0';
        barsEl.style.transform = 'translateY(4px)';
        labelEl.style.opacity = '0';

        setTimeout(() => {
          labelEl.textContent = view.label + ' usage';
          barsEl.innerHTML = view.bars.map((b, i) => {
            let cls = 'widget-mock__bar';
            if (i === view.peak) cls += ' widget-mock__bar--peak';
            else if (i === view.today) cls += ' widget-mock__bar--today';
            return '<div class="' + cls + '" style="--h: ' + b.h + '%;"><span>' + b.l + '</span></div>';
          }).join('');

          // Fade in
          requestAnimationFrame(() => {
            barsEl.style.opacity = '1';
            barsEl.style.transform = 'translateY(0)';
            labelEl.style.opacity = '1';
          });
        }, 250);
      }

      function cycleChart() {
        viewIndex = (viewIndex + 1) % chartViews.length;
        renderBars(chartViews[viewIndex]);
      }

      // Start cycling when card is visible
      const chartObs = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) {
          cycleInt = setInterval(cycleChart, 3000);
        } else {
          clearInterval(cycleInt);
        }
      }, { threshold: 0.2 });
      chartObs.observe(card);

      card.addEventListener('mouseenter', () => {
        tickInt = setInterval(() => {
          total += 0.8 + Math.random() * 2.4;
          today += 0.3 + Math.random() * 1.2;
          cost += 0.01 + Math.random() * 0.08;
          if (totalEl) totalEl.textContent = total >= 1000 ? (total/1000).toFixed(1) + 'B' : total.toFixed(1) + 'M';
          if (todayEl) todayEl.textContent = fmt(today);
          if (costEl) costEl.textContent = '~$' + cost.toFixed(2);
        }, 800);
      });

      card.addEventListener('mouseleave', () => {
        clearInterval(tickInt);
      });
    })();

    // Mobile: tap button to expand/collapse all project cards
    if (window.matchMedia('(max-width: 768px)').matches) {
      const btn = document.getElementById('projects-expand-btn');
      const cards = document.querySelectorAll('.project-card.has-preview');
      let expanded = false;
      btn.addEventListener('click', () => {
        expanded = !expanded;
        cards.forEach(c => c.classList.toggle('in-view', expanded));
        btn.textContent = expanded ? '(tap to collapse)' : '(tap to expand)';
      });
    }

  </script>
</BaseLayout>

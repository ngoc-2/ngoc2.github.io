---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const projects = [
  {
    title: 'Yerb',
    desc: 'Personal AI assistant running 24/7 on a Mac Mini. Manages calendar, automates coursework, runs autonomous builds overnight.',
    tags: ['Python', 'Anthropic', 'Automation'],
    link: '/projects/yerb',
    status: 'Active',
  },
  {
    title: 'Token Tracker',
    desc: 'Native macOS widget tracking Claude Code usage in real-time. Parses sessions, shows per-model breakdowns and costs.',
    tags: ['Swift', 'SwiftUI', 'macOS'],
    link: '/projects/token-tracker',
    status: 'Active',
  },
  {
    title: 'Fuel',
    desc: 'Native iOS calorie tracker with AI food parsing, barcode scanning, HealthKit sync, and Apple Watch companion.',
    tags: ['Swift', 'SwiftUI', 'HealthKit', 'AI'],
    link: '/projects/fuel',
    status: 'Live',
  },
  {
    title: 'Vault Keeper',
    desc: 'AI-powered accountability system built on Obsidian. Reads journals, detects behavioral patterns, generates briefs.',
    tags: ['Obsidian', 'Python', 'AI'],
    link: '/projects/vault-keeper',
    status: 'Legacy',
  },
  {
    title: 'Neural Networks',
    desc: 'Custom neural network library — backpropagation, activation functions, convolutional layers — no frameworks.',
    tags: ['Python', 'NumPy', 'ML'],
    status: 'In Progress',
  },
];

// Get all B&W photos for slideshow
const bwDir = path.join(process.cwd(), 'public', 'photos', 'bw');
const bwPhotos = fs.readdirSync(bwDir)
  .filter(f => /\.(jpg|jpeg|png|webp)$/i.test(f))
  .map(f => `/photos/bw/${f}`);

const galleryPhotos = [
  { src: '/photos/bw/DSCF4108.jpg', credit: 'Black & White' },
  { src: '/photos/bw/DSCF3767.jpg', credit: 'Black & White' },
  { src: '/photos/bw/DSCF7488.jpg', credit: 'Black & White' },
  { src: '/photos/ecuador/IMG_3640.JPG', credit: 'Ecuador' },
  { src: '/photos/ecuador/IMG_4688.JPG', credit: 'Ecuador' },
];
---

<BaseLayout>
  <!-- ═══════════ HERO ═══════════ -->
  <section class="home-hero" style="position: relative;">
    <div class="hero-overlap">
      <div class="hero-slideshow" id="hero-slideshow">
        {bwPhotos.slice(0, 12).map((src, i) => (
          <img
            src={src}
            alt=""
            class={`hero-slideshow__img ${i === 0 ? 'is-active' : ''}`}
            loading={i < 2 ? 'eager' : 'lazy'}
          />
        ))}
      </div>
      <div class="hero-overlap__text">
        <span class="display display--1">Jake</span>
        <span class="display display--1">Davis</span>
      </div>
    </div>
  </section>

  <!-- ═══════════ ABOUT ═══════════ -->
  <section id="about" class="js-in" style="padding: clamp(4rem, 8vw, 10rem) 30px;">
    <div class="about-grid">
      <div>
        <div class="lead" style="font-size: 13px; line-height: 1.8; text-transform: none; color: var(--text-2);">
          <p style="margin-bottom: 1.5em;">Software developer. Photographer. Neuroscience student. Creator.</p>
          <p style="margin-bottom: 1.5em;">I build AI systems and automation tools — agents that run autonomously, software that removes me from the loop.</p>
          <p style="margin-bottom: 1.5em;">Right now: a multi-agent system on a Mac Mini that manages my schedule, trades crypto and prediction markets, and ships code on its own. The commit history doesn't sleep.</p>
          <p style="margin-bottom: 1.5em;">I shoot photos. Mostly outdoors, mostly film.</p>
        </div>
        <div style="display: flex; flex-wrap: wrap; gap: 1.2rem; margin-top: 2rem; font-size: 10px; color: var(--grey); letter-spacing: 0.05em;">
          <div>
            <div class="lead" style="font-size: 10px;">Python · JavaScript · TypeScript · Swift · SQL · Bash · AppleScript</div>
          </div>
          <div>
            <div class="lead" style="font-size: 10px;">Astro · React · Node.js · SQLite · Docker · Git</div>
          </div>
          <div>
            <div class="lead" style="font-size: 10px;">Claude API · OpenAI API · Canvas API · Brave Search API · ElevenLabs API · Telegram API · Polymarket API · Tailscale · Linux · macOS</div>
          </div>
          <div>
            <div class="lead" style="font-size: 10px;">AI/ML · Agent Architecture · Automation · Web Dev · Systems Design · Market Analysis</div>
          </div>
        </div>
      </div>
      <div>
        <div class="agent-terminal js-in" id="agent-terminal">
          <div class="agent-terminal__header">
            <span class="agent-terminal__dot" style="background: #ff5f57;"></span>
            <span class="agent-terminal__dot" style="background: #febc2e;"></span>
            <span class="agent-terminal__dot" style="background: #28c840;"></span>
            <span class="agent-terminal__title">yerb &mdash; mac mini</span>
          </div>
          <div class="agent-terminal__body" id="agent-terminal-body"></div>
          <div class="agent-terminal__status">
            <div class="term-status__left">
              <span class="term-status__badge term-status__badge--auto">> auto-accept</span>
              <span class="term-status__item">Yerb 2.8</span>
            </div>
            <div class="term-status__right">
              <span class="term-status__item" id="term-tokens">0 tokens</span>
              <span class="term-status__ctx">
                <span class="term-ctx-bar"><span class="term-ctx-fill" id="term-ctx-fill"></span></span>
                <span id="term-ctx-pct">0%</span>
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ BUILD ═══════════ -->
  <section class="build-section js-in" id="build">
    <div class="build-section__grid">
      <!-- Visual: Cycling build visuals -->
      <div class="build-visual" id="build-visual">
        <!-- 0: site — Miniature Website Preview -->
        <div class="build-vis build-vis--active" data-vis="site">
          <div class="vis-site__chrome">
            <div class="vis-site__dots">
              <span class="vis-site__dot" style="background:#ff5f57;"></span>
              <span class="vis-site__dot" style="background:#febc2e;"></span>
              <span class="vis-site__dot" style="background:#28c840;"></span>
            </div>
            <div class="vis-site__url-bar">
              <svg class="vis-site__lock" width="8" height="8" viewBox="0 0 24 24" fill="currentColor"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM12 17c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3-9H9V6c0-1.66 1.34-3 3-3s3 1.34 3 3v2z"/></svg>
              <span class="vis-site__url-text">yoursite.com</span>
            </div>
          </div>
          <div class="vis-site__page">
            <div class="vis-site__nav">
              <span class="vis-site__nav-logo">acme</span>
              <div class="vis-site__nav-links">
                <span class="vis-site__nav-link">Home</span>
                <span class="vis-site__nav-link">Pricing</span>
                <span class="vis-site__nav-link">Blog</span>
              </div>
              <span class="vis-site__nav-cta">Sign up</span>
            </div>
            <div class="vis-site__hero">
              <span class="vis-site__hero-badge">&#9679; Now in beta</span>
              <div class="vis-site__hero-h1">Ship faster.</div>
              <div class="vis-site__hero-h1 vis-site__hero-h1--accent">Build smarter.</div>
              <p class="vis-site__hero-sub">The modern platform for teams who want to move fast without breaking things.</p>
              <div class="vis-site__hero-actions">
                <span class="vis-site__btn vis-site__btn--primary">Get started</span>
                <span class="vis-site__btn vis-site__btn--ghost">View docs &#8594;</span>
              </div>
            </div>
            <div class="vis-site__stats-row">
              <div class="vis-site__stat-block">
                <span class="vis-site__stat-num">99.9%</span>
                <span class="vis-site__stat-desc">Uptime</span>
              </div>
              <div class="vis-site__stat-block">
                <span class="vis-site__stat-num">2.4M</span>
                <span class="vis-site__stat-desc">Requests/day</span>
              </div>
              <div class="vis-site__stat-block">
                <span class="vis-site__stat-num">&lt;50ms</span>
                <span class="vis-site__stat-desc">Avg latency</span>
              </div>
            </div>
          </div>
          <div class="vis-site__lighthouse">
            <div class="vis-site__lh-score">
              <span class="vis-site__lh-val build-browser__stat-val--green">100</span>
              <span class="vis-site__lh-label">Performance</span>
            </div>
            <div class="vis-site__lh-score">
              <span class="vis-site__lh-val build-browser__stat-val--green">100</span>
              <span class="vis-site__lh-label">Accessibility</span>
            </div>
            <div class="vis-site__lh-score">
              <span class="vis-site__lh-val build-browser__stat-val--green">100</span>
              <span class="vis-site__lh-label">SEO</span>
            </div>
            <div class="vis-site__lh-score">
              <span class="vis-site__lh-val">0.4s</span>
              <span class="vis-site__lh-label">Load</span>
            </div>
          </div>
        </div>

        <!-- 1: app — Fuel Calorie Tracker -->
        <div class="build-vis" data-vis="app">
          <div class="vis-app__phone">
            <div class="vis-app__device">
              <div class="vis-app__status-bar">
                <span class="vis-app__time">9:41</span>
                <div class="vis-app__status-icons">
                  <svg class="vis-app__icon-signal" viewBox="0 0 16 12" fill="rgba(255,255,255,0.5)">
                    <rect x="0" y="9" width="3" height="3" rx="0.5"/>
                    <rect x="4.5" y="6" width="3" height="6" rx="0.5"/>
                    <rect x="9" y="3" width="3" height="9" rx="0.5"/>
                    <rect x="13.5" y="0" width="3" height="12" rx="0.5" fill-opacity="0.3"/>
                  </svg>
                  <svg class="vis-app__icon-battery" viewBox="0 0 28 13" fill="none">
                    <rect x="0.5" y="0.5" width="23" height="12" rx="2.5" stroke="rgba(255,255,255,0.4)" stroke-width="1"/>
                    <rect x="25" y="4" width="2.5" height="5" rx="1" fill="rgba(255,255,255,0.25)"/>
                    <rect x="2" y="2" width="16" height="9" rx="1.5" fill="rgba(52,199,89,0.7)"/>
                  </svg>
                </div>
              </div>
              <div class="vis-app__island"></div>
              <div class="vis-app__screen">
                <div class="vis-app__header">
                  <span class="vis-app__header-title">Today</span>
                  <span class="vis-app__header-date">Mar 4</span>
                </div>
                <div class="vis-app__ring-section">
                  <div class="vis-app__ring-container">
                    <svg class="vis-app__ring-svg" viewBox="0 0 80 80">
                      <circle cx="40" cy="40" r="32" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="6"/>
                      <circle cx="40" cy="40" r="32" fill="none" stroke="rgba(52,199,89,0.75)" stroke-width="6" stroke-dasharray="201" stroke-dashoffset="54" stroke-linecap="round" transform="rotate(-90 40 40)"/>
                    </svg>
                    <div class="vis-app__ring-label">
                      <span class="vis-app__ring-cal">1,847</span>
                      <span class="vis-app__ring-unit">kcal</span>
                    </div>
                  </div>
                  <div class="vis-app__ring-meta">
                    <span class="vis-app__ring-goal">of 2,400 goal</span>
                    <span class="vis-app__ring-remaining">553 remaining</span>
                  </div>
                </div>
                <div class="vis-app__macros">
                  <div class="vis-app__macro">
                    <div class="vis-app__macro-top">
                      <span class="vis-app__macro-name">Protein</span>
                      <span class="vis-app__macro-val">142g</span>
                    </div>
                    <div class="vis-app__macro-track"><div class="vis-app__macro-fill vis-app__macro-fill--protein"></div></div>
                  </div>
                  <div class="vis-app__macro">
                    <div class="vis-app__macro-top">
                      <span class="vis-app__macro-name">Carbs</span>
                      <span class="vis-app__macro-val">186g</span>
                    </div>
                    <div class="vis-app__macro-track"><div class="vis-app__macro-fill vis-app__macro-fill--carbs"></div></div>
                  </div>
                  <div class="vis-app__macro">
                    <div class="vis-app__macro-top">
                      <span class="vis-app__macro-name">Fat</span>
                      <span class="vis-app__macro-val">61g</span>
                    </div>
                    <div class="vis-app__macro-track"><div class="vis-app__macro-fill vis-app__macro-fill--fat"></div></div>
                  </div>
                </div>
                <div class="vis-app__divider"></div>
                <div class="vis-app__meals">
                  <div class="vis-app__meals-header">
                    <span class="vis-app__meals-title">Meals</span>
                    <span class="vis-app__meals-count">3 logged</span>
                  </div>
                  <div class="vis-app__meal">
                    <div class="vis-app__meal-icon vis-app__meal-icon--breakfast"></div>
                    <div class="vis-app__meal-info">
                      <span class="vis-app__meal-name">Breakfast</span>
                      <span class="vis-app__meal-desc">Eggs, toast, avocado</span>
                    </div>
                    <span class="vis-app__meal-kcal">520</span>
                  </div>
                  <div class="vis-app__meal">
                    <div class="vis-app__meal-icon vis-app__meal-icon--lunch"></div>
                    <div class="vis-app__meal-info">
                      <span class="vis-app__meal-name">Lunch</span>
                      <span class="vis-app__meal-desc">Chicken bowl, rice</span>
                    </div>
                    <span class="vis-app__meal-kcal">785</span>
                  </div>
                  <div class="vis-app__meal vis-app__meal--active">
                    <div class="vis-app__meal-icon vis-app__meal-icon--snack"></div>
                    <div class="vis-app__meal-info">
                      <span class="vis-app__meal-name">Snack</span>
                      <span class="vis-app__meal-desc">Protein shake</span>
                    </div>
                    <span class="vis-app__meal-kcal">542</span>
                  </div>
                </div>
              </div>
              <div class="vis-app__home-bar"></div>
            </div>
          </div>
        </div>

        <!-- 2: software — CI/CD Pipeline -->
        <div class="build-vis" data-vis="software">
          <div class="vis-sw__bar">
            <span class="vis-wdot" style="background:#ff5f57;"></span>
            <span class="vis-wdot" style="background:#febc2e;"></span>
            <span class="vis-wdot" style="background:#28c840;"></span>
            <span class="vis-sw__title">CI / CD</span>
            <span class="vis-sw__badge">&#9679; main</span>
          </div>
          <div class="vis-sw__body">
            <div class="vis-sw__pipeline">
              <div class="vis-sw__stage vis-sw__stage--pass">
                <div class="vis-sw__stage-icon">&#10004;</div>
                <div class="vis-sw__stage-label">Build</div>
                <div class="vis-sw__stage-time">23s</div>
              </div>
              <div class="vis-sw__connector vis-sw__connector--pass"></div>
              <div class="vis-sw__stage vis-sw__stage--pass">
                <div class="vis-sw__stage-icon">&#10004;</div>
                <div class="vis-sw__stage-label">Test</div>
                <div class="vis-sw__stage-time">1m 47s</div>
              </div>
              <div class="vis-sw__connector vis-sw__connector--pass"></div>
              <div class="vis-sw__stage vis-sw__stage--pass">
                <div class="vis-sw__stage-icon">&#10004;</div>
                <div class="vis-sw__stage-label">Lint</div>
                <div class="vis-sw__stage-time">12s</div>
              </div>
              <div class="vis-sw__connector vis-sw__connector--active"></div>
              <div class="vis-sw__stage vis-sw__stage--active">
                <div class="vis-sw__stage-icon vis-sw__spinner"></div>
                <div class="vis-sw__stage-label">Deploy</div>
                <div class="vis-sw__stage-time">...</div>
              </div>
            </div>
            <div class="vis-sw__cols">
              <div class="vis-sw__panel">
                <div class="vis-sw__panel-head">Test Suites</div>
                <div class="vis-sw__suite">
                  <span class="vis-sw__suite-icon vis-sw__suite-icon--pass">&#10004;</span>
                  <span class="vis-sw__suite-name">auth.test.ts</span>
                  <span class="vis-sw__suite-count">24 passed</span>
                </div>
                <div class="vis-sw__suite">
                  <span class="vis-sw__suite-icon vis-sw__suite-icon--pass">&#10004;</span>
                  <span class="vis-sw__suite-name">api.test.ts</span>
                  <span class="vis-sw__suite-count">61 passed</span>
                </div>
                <div class="vis-sw__suite">
                  <span class="vis-sw__suite-icon vis-sw__suite-icon--pass">&#10004;</span>
                  <span class="vis-sw__suite-name">db.test.ts</span>
                  <span class="vis-sw__suite-count">38 passed</span>
                </div>
                <div class="vis-sw__suite">
                  <span class="vis-sw__suite-icon vis-sw__suite-icon--pass">&#10004;</span>
                  <span class="vis-sw__suite-name">utils.test.ts</span>
                  <span class="vis-sw__suite-count">24 passed</span>
                </div>
                <div class="vis-sw__totals">
                  <span class="vis-sw__totals-pass">147 passed</span>
                  <span class="vis-sw__totals-sep">&middot;</span>
                  <span class="vis-sw__totals-fail">0 failed</span>
                </div>
              </div>
              <div class="vis-sw__panel">
                <div class="vis-sw__panel-head">Commits</div>
                <div class="vis-sw__commits">
                  <div class="vis-sw__commit">
                    <div class="vis-sw__commit-dot"></div>
                    <div class="vis-sw__commit-line"></div>
                    <div class="vis-sw__commit-info">
                      <span class="vis-sw__commit-msg">feat: add rate limiting</span>
                      <span class="vis-sw__commit-meta">a3f2c91 &middot; 4m ago</span>
                    </div>
                  </div>
                  <div class="vis-sw__commit">
                    <div class="vis-sw__commit-dot"></div>
                    <div class="vis-sw__commit-line"></div>
                    <div class="vis-sw__commit-info">
                      <span class="vis-sw__commit-msg">fix: token refresh race</span>
                      <span class="vis-sw__commit-meta">e7b1d04 &middot; 22m ago</span>
                    </div>
                  </div>
                  <div class="vis-sw__commit">
                    <div class="vis-sw__commit-dot"></div>
                    <div class="vis-sw__commit-line"></div>
                    <div class="vis-sw__commit-info">
                      <span class="vis-sw__commit-msg">refactor: extract middleware</span>
                      <span class="vis-sw__commit-meta">1c8e3fa &middot; 1h ago</span>
                    </div>
                  </div>
                  <div class="vis-sw__commit">
                    <div class="vis-sw__commit-dot vis-sw__commit-dot--merge"></div>
                    <div class="vis-sw__commit-info">
                      <span class="vis-sw__commit-msg">merge: feature/auth</span>
                      <span class="vis-sw__commit-meta">9d4a2b7 &middot; 3h ago</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- 3: assistant — Real Chat -->
        <div class="build-vis" data-vis="assistant">
          <div class="vis-chat2__bar">
            <div class="vis-chat2__avatar"></div>
            <span class="vis-chat2__name">Claude</span>
            <span class="vis-chat2__online">&#9679;</span>
          </div>
          <div class="vis-chat2__body">
            <div class="vis-chat2__msg vis-chat2__msg--user">Build me a dashboard</div>
            <div class="vis-chat2__msg vis-chat2__msg--ai">I'll set up React with D3 for the charts. Adding real-time data via WebSocket and a responsive grid layout.</div>
            <div class="vis-chat2__msg vis-chat2__msg--user">Add dark mode too</div>
            <div class="vis-chat2__msg vis-chat2__msg--ai"><span class="vis-chat2__typing"><span></span><span></span><span></span></span></div>
          </div>
          <div class="vis-chat2__input">
            <div class="vis-chat2__field"></div>
            <div class="vis-chat2__send">&#8593;</div>
          </div>
        </div>

        <!-- 4: AI — Model Inference -->
        <div class="build-vis" data-vis="AI">
          <div class="vis-ai2__bar">
            <span class="vis-wdot" style="background:#ff5f57;"></span>
            <span class="vis-wdot" style="background:#febc2e;"></span>
            <span class="vis-wdot" style="background:#28c840;"></span>
            <span class="vis-ai2__method">POST</span>
            <span class="vis-ai2__endpoint">/v1/chat/completions</span>
            <span class="vis-ai2__status">200</span>
            <span class="vis-ai2__stream-badge">stream</span>
          </div>
          <div class="vis-ai2__body">
            <div class="vis-ai2__section">
              <span class="vis-ai2__section-label">request</span>
              <pre class="vis-ai2__code">&#123;
  <span class="vis-ai2__k">"model"</span>: <span class="vis-ai2__s">"claude-sonnet-4-20250514"</span>,
  <span class="vis-ai2__k">"max_tokens"</span>: <span class="vis-ai2__n">1024</span>,
  <span class="vis-ai2__k">"messages"</span>: [&#123;
    <span class="vis-ai2__k">"role"</span>: <span class="vis-ai2__s">"user"</span>,
    <span class="vis-ai2__k">"content"</span>: <span class="vis-ai2__s">"Analyze this dataset"</span>
  &#125;]
&#125;</pre>
            </div>
            <div class="vis-ai2__section vis-ai2__section--response">
              <span class="vis-ai2__section-label">response <span class="vis-ai2__live-dot"></span></span>
              <div class="vis-ai2__stream">
                <span class="vis-ai2__token vis-ai2__token--1">I'll</span><span class="vis-ai2__token vis-ai2__token--2"> start</span><span class="vis-ai2__token vis-ai2__token--3"> by</span><span class="vis-ai2__token vis-ai2__token--4"> loading</span><span class="vis-ai2__token vis-ai2__token--5"> the</span><span class="vis-ai2__token vis-ai2__token--6"> CSV</span><span class="vis-ai2__token vis-ai2__token--7"> and</span><span class="vis-ai2__token vis-ai2__token--8"> checking</span><span class="vis-ai2__token vis-ai2__token--9"> for</span><span class="vis-ai2__token vis-ai2__token--10"> null</span><span class="vis-ai2__token vis-ai2__token--11"> values</span><span class="vis-ai2__token vis-ai2__token--12"> across</span><span class="vis-ai2__token vis-ai2__token--13"> all</span><span class="vis-ai2__token vis-ai2__token--14"> columns,</span><span class="vis-ai2__token vis-ai2__token--15"> then</span><span class="vis-ai2__token vis-ai2__token--16"> compute</span><span class="vis-ai2__token vis-ai2__token--17"> summary</span><span class="vis-ai2__token vis-ai2__token--18"> statistics</span><span class="vis-ai2__cursor"></span>
              </div>
            </div>
          </div>
          <div class="vis-ai2__footer">
            <div class="vis-ai2__metric">
              <span class="vis-ai2__metric-label">input</span>
              <span class="vis-ai2__metric-value">24 tok</span>
            </div>
            <div class="vis-ai2__metric">
              <span class="vis-ai2__metric-label">output</span>
              <span class="vis-ai2__metric-value vis-ai2__metric-value--green">38 tok</span>
            </div>
            <div class="vis-ai2__metric">

  <script is:inline>
    // ═══════════════════════════════════════
    // FUEL LANDING — AI TYPING ANIMATION
    // ═══════════════════════════════════════
    (function() {
      var typed = document.getElementById('flp-ai-typed');
      var parsing = document.getElementById('flp-ai-parsing');
      var foods = document.getElementById('flp-ai-foods');
      if (!typed || !parsing || !foods) return;

      var text = '2 eggs, sourdough toast with butter, black coffee';
      var i = 0;
      var started = false;

      function startTyping() {
        if (started) return;
        started = true;

        // Small delay before typing starts
        setTimeout(function() {
          var interval = setInterval(function() {
            if (i < text.length) {
              typed.textContent += text[i];
              i++;
            } else {
              clearInterval(interval);
              // Show parsing state
              setTimeout(function() {
                parsing.style.display = 'flex';
                // Show results
                setTimeout(function() {
                  parsing.style.display = 'none';
                  foods.style.display = 'block';
                }, 1800);
              }, 400);
            }
          }, 45);
        }, 600);
      }

      // Use IntersectionObserver to trigger when demo comes into view
      var demoPhone = document.getElementById('fuel-demo-phone');
      if (demoPhone && 'IntersectionObserver' in window) {
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              startTyping();
              observer.disconnect();
            }
          });
        }, { threshold: 0.4 });
        observer.observe(demoPhone);
      } else {
        // Fallback: start after delay
        setTimeout(startTyping, 2000);
      }
    })();

    // ═══════════════════════════════════════
    // FUEL LANDING — HERO PHONE FLOAT ANIMATION
    // ═══════════════════════════════════════
    (function() {
      var phone = document.getElementById('fuel-hero-phone');
      if (!phone || typeof gsap === 'undefined') return;

      // Wait for GSAP to be available (it's loaded in BaseLayout)
      function initFloat() {
        // Initial entrance
        gsap.fromTo(phone, {
          y: 40,
          opacity: 0,
        }, {
          y: 0,
          opacity: 1,
          duration: 1.4,
          delay: 0.5,
          ease: 'power4.out',
        });

        // Gentle floating
        gsap.to(phone, {
          y: -8,
          duration: 3,
          ease: 'sine.inOut',
          yoyo: true,
          repeat: -1,
          delay: 2,
        });
      }

      // GSAP is loaded via BaseLayout, but might not be ready yet
      if (typeof gsap !== 'undefined' && gsap.to) {
        initFloat();
      } else {
        window.addEventListener('load', initFloat);
      }
    })();
  </script>


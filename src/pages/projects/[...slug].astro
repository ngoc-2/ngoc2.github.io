        let opus = 8.4, sonnet = 4.1, haiku = 1.7, budget = 67;
        let elapsed = 9257; // seconds

        function fmtM(n) { return n.toFixed(1) + 'M'; }
        function fmtK(n) { return n >= 1000 ? (n/1000).toFixed(1) + 'M' : n.toFixed(1) + 'K'; }
        function fmtTime(s) {
          const h = Math.floor(s/3600), m = Math.floor((s%3600)/60), sec = s%60;
          return String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(sec).padStart(2,'0')+' elapsed';
        }

        setInterval(function() {
          total += 0.3 + Math.random() * 1.2;
          today += 0.1 + Math.random() * 0.8;
          cost += 0.005 + Math.random() * 0.04;
          budget = Math.min(budget + 0.15 + Math.random() * 0.3, 98);
          elapsed++;

          var r = Math.random();
          if (r < 0.5) opus += 0.2 + Math.random() * 0.8;
          else if (r < 0.8) sonnet += 0.1 + Math.random() * 0.5;
          else haiku += 0.05 + Math.random() * 0.3;

          if (totalEl) totalEl.textContent = fmtM(total);
          if (todayEl) todayEl.textContent = fmtK(today);
          if (costEl) costEl.textContent = '~$' + cost.toFixed(2);
          if (opusEl) opusEl.textContent = fmtM(opus);
          if (sonnetEl) sonnetEl.textContent = fmtM(sonnet);
          if (haikuEl) haikuEl.textContent = fmtM(haiku);
          if (budgetPctEl) budgetPctEl.textContent = Math.round(budget) + '%';
          if (budgetFillEl) {
            budgetFillEl.style.width = budget + '%';
            if (budget > 85) budgetFillEl.style.background = 'rgba(255, 69, 58, 0.7)';
            else if (budget > 60) budgetFillEl.style.background = 'rgba(255, 149, 0, 0.6)';
          }
          if (discordDetailEl) discordDetailEl.textContent = 'Lifetime: ' + fmtM(total) + ' tokens';
          if (discordStateEl) discordStateEl.textContent = 'Today: ' + fmtK(today) + ' | Opus';
          if (discordTimeEl) discordTimeEl.textContent = fmtTime(elapsed);
        }, 1200);

        // === Chart cycling ===
        var barsEl = document.getElementById('wp-bars');
        var labelEl = document.getElementById('wp-chart-label');
        var chartViews = [
          { label: 'Hourly', bars: [
            {h:20,l:'6a'},{h:45,l:'8a'},{h:78,l:'10a'},{h:55,l:'12p'},
            {h:30,l:'2p'},{h:65,l:'4p'},{h:88,l:'6p'},{h:72,l:'8p'},{h:40,l:'10p'}
          ], peak: 6 },
          { label: '7-day', bars: [
            {h:35,l:'M'},{h:62,l:'T'},{h:48,l:'W'},{h:85,l:'T'},
            {h:71,l:'F'},{h:40,l:'S'},{h:55,l:'S'}
          ], peak: 3, today: 6 },
          { label: 'Monthly', bars: [
            {h:30,l:'Sep'},{h:52,l:'Oct'},{h:68,l:'Nov'},{h:45,l:'Dec'},
            {h:74,l:'Jan'},{h:90,l:'Feb'},{h:58,l:'Mar'}
          ], peak: 5, today: 6 },
        ];
        var ci = 0;
        setInterval(function() {
          ci = (ci + 1) % chartViews.length;
          var v = chartViews[ci];
          if (!barsEl || !labelEl) return;
          barsEl.style.opacity = '0';
          barsEl.style.transform = 'translateY(4px)';
          labelEl.style.opacity = '0';
          setTimeout(function() {
            labelEl.textContent = v.label + ' usage';
            barsEl.innerHTML = v.bars.map(function(b, i) {
              var cls = 'widget-page__bar';
              if (i === v.peak) cls += ' widget-page__bar--peak';
              else if (i === v.today) cls += ' widget-page__bar--today';
              return '<div class="' + cls + '" style="--h:' + b.h + '%;"><span>' + b.l + '</span></div>';
            }).join('');
            requestAnimationFrame(function() {
              barsEl.style.opacity = '1';
              barsEl.style.transform = 'translateY(0)';
              labelEl.style.opacity = '1';
            });
          }, 250);
        }, 3000);

        // === Scroll-driven screen switching ===
        var screens = document.querySelectorAll('.widget-page__screen');
        var currentScreen = 0;

        function showScreen(idx) {
          if (idx === currentScreen) return;

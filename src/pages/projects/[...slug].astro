    <script is:inline>
      (function() {
        // === Typing animation for AI input screen ===
        var inputField = document.getElementById('fuel-input-field');
        var parsingEl = document.getElementById('fuel-parsing');
        var foodsEl = document.getElementById('fuel-foods');
        var text = '2 eggs, sourdough toast with butter, black coffee';
        var typed = '';
        var charIdx = 0;
        var typingDone = false;
        var showingResults = false;

        function typeLoop() {
          if (charIdx < text.length) {
            typed += text[charIdx];
            charIdx++;
            inputField.innerHTML = typed + '<span class="fuel-input__cursor">|</span>';
            setTimeout(typeLoop, 40 + Math.random() * 60);
          } else if (!typingDone) {
            typingDone = true;
            // Show parsing state
            parsingEl.style.display = 'flex';
            foodsEl.style.display = 'none';
            setTimeout(function() {
              parsingEl.style.display = 'none';
              foodsEl.style.display = 'block';
              showingResults = true;
              // Reset after a while
              setTimeout(resetTyping, 6000);
            }, 1800);
          }
        }

        function resetTyping() {
          typed = '';
          charIdx = 0;
          typingDone = false;
          showingResults = false;
          inputField.innerHTML = '<span class="fuel-input__cursor">|</span>';
          parsingEl.style.display = 'none';
          foodsEl.style.display = 'none';
          setTimeout(typeLoop, 1500);
        }

        // Start typing when AI screen becomes visible
        var aiStarted = false;

        // === Scroll-driven screen switching ===
        var screens = document.querySelectorAll('.fuel-screen');
        var currentScreen = 0;

        function showFuelScreen(idx) {
          if (idx === currentScreen) return;
          currentScreen = idx;
          screens.forEach(function(s) { s.classList.remove('fuel-screen--active'); });
          screens[idx].classList.add('fuel-screen--active');
          // Start typing animation when AI input screen appears
          if (idx === 1 && !aiStarted) {
            aiStarted = true;
            setTimeout(typeLoop, 600);
          }
        }

        function initFuelScroll() {
          if (typeof ScrollTrigger === 'undefined') {
            setTimeout(initFuelScroll, 100);
            return;
          }
          var proseEl = document.querySelector('.project-article--has-sidebar .prose');
          if (!proseEl) return;
          var headings = proseEl.querySelectorAll('h2');
          // The Problem, The Approach → 0 (Dashboard)
          // Architecture, Features → 1 (AI Input)
          // Key Decisions → 2 (Meals)
          // Stack → 3 (Integrations)
          var screenMap = [0, 0, 1, 1, 2, 3];

          headings.forEach(function(h, i) {
            var target = i < screenMap.length ? screenMap[i] : 3;
            ScrollTrigger.create({
              trigger: h,
              start: 'top 60%',
              onEnter: function() { showFuelScreen(target); },
              onEnterBack: function() {
                var prev = i > 0 && (i - 1) < screenMap.length ? screenMap[i - 1] : 0;
                showFuelScreen(i === 0 ? 0 : prev);
              }
            });
          });
        }
        initFuelScroll();

        // === Dashboard number ticking ===
        var eaten = 1216, protein = 86, carbs = 134, fat = 42;
        var calLeft = document.getElementById('fuel-cal-left');
        var eatenEl = document.getElementById('fuel-eaten');
        var remainingStatEl = document.getElementById('fuel-remaining-stat');
        var ringEl = document.getElementById('fuel-ring');
        var proteinEl = document.getElementById('fuel-protein');
        var carbsEl = document.getElementById('fuel-carbs');
        var fatEl = document.getElementById('fuel-fat');
        var proteinBar = document.getElementById('fuel-protein-bar');
        var carbsBar = document.getElementById('fuel-carbs-bar');
        var fatBar = document.getElementById('fuel-fat-bar');

        setInterval(function() {
          var add = Math.floor(2 + Math.random() * 8);
          eaten = Math.min(eaten + add, 2000);
          protein = Math.min(protein + Math.floor(Math.random() * 2), 150);
          carbs = Math.min(carbs + Math.floor(Math.random() * 3), 250);
          fat = Math.min(fat + Math.floor(Math.random() * 2), 70);

          var remaining = Math.max(2000 - eaten, 0);
          var pct = eaten / 2000;
          var dashoffset = 327 - (327 * Math.min(pct, 1));

          if (calLeft) calLeft.textContent = remaining;
          if (eatenEl) eatenEl.textContent = eaten.toLocaleString();
          if (remainingStatEl) remainingStatEl.textContent = remaining.toLocaleString();
          if (ringEl) ringEl.setAttribute('stroke-dashoffset', dashoffset);
          if (proteinEl) proteinEl.textContent = protein + ' / 150g';
          if (carbsEl) carbsEl.textContent = carbs + ' / 250g';
          if (fatEl) fatEl.textContent = fat + ' / 70g';
          if (proteinBar) proteinBar.style.width = Math.min((protein / 150) * 100, 100) + '%';
          if (carbsBar) carbsBar.style.width = Math.min((carbs / 250) * 100, 100) + '%';
          if (fatBar) fatBar.style.width = Math.min((fat / 70) * 100, 100) + '%';

          if (pct >= 1 && ringEl) ringEl.setAttribute('stroke', '#E64D4D');
        }, 1500);
      })();
    </script>
  )}


    <script is:inline>
      (function() {
        // === Stats ticking ===
        const totalEl = document.getElementById('wp-total');
        const todayEl = document.getElementById('wp-today');
        const costEl = document.getElementById('wp-cost');
        const opusEl = document.getElementById('wp-opus');
        const sonnetEl = document.getElementById('wp-sonnet');
        const haikuEl = document.getElementById('wp-haiku');
        const budgetPctEl = document.getElementById('wp-budget-pct');

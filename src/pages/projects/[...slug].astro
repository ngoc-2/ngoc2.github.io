---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const allProjects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const currentIndex = allProjects.findIndex((p) => p.id === project.id);
const prevProject = currentIndex > 0 ? allProjects[currentIndex - 1] : null;
const nextProject = currentIndex < allProjects.length - 1 ? allProjects[currentIndex + 1] : null;

const isTokenTracker = project.id === 'token-tracker';
const isFuel = project.id === 'fuel';
const isYerb = project.id === 'yerb';
const isScraper = project.id === 'marketplace-scraper';
const isVault = project.id === 'vault-keeper';
const isNeural = project.id === 'neural-networks';
const hasSidebar = isTokenTracker || isFuel || isYerb || isScraper || isVault || isNeural;
---

<BaseLayout title={`${project.data.title} — Steven Nguyen`} description={project.data.description}>
  <article class={`project-article ${hasSidebar ? 'project-article--has-sidebar' : ''}`}>
    <div class="project-article__main">
      <!-- Back link -->
      <a href="/#work" class="lead" style="display: inline-block; margin-bottom: 3rem; color: var(--grey);">
        ← Back to work
      </a>

      <!-- Hero -->
      <header style="margin-bottom: 3rem;">
        <h1 class="display display--2" style="margin-bottom: 1rem;">
          {project.data.title}
        </h1>
        <p class="lead" style="font-size: 13px; line-height: 1.8; text-transform: none; color: var(--text-2); margin-bottom: 1.5rem;">
          {project.data.description}
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 1em; margin-bottom: 1.5rem;">
          {project.data.tags.map((tag: string) => (
            <span class="lead" style="font-size: 11px; color: var(--grey);">{tag}</span>
          ))}
        </div>
        {(project.data.github || project.data.live) && (
          <div style="display: flex; gap: 1.5em;">
            {project.data.github && (
              <a href={project.data.github} target="_blank" class="lead u-g">GitHub →</a>
            )}
            {project.data.live && (
              <a href={project.data.live} target="_blank" class="lead u-g">Live Demo →</a>
            )}
          </div>
        )}
      </header>

      <!-- Content -->
      <div class="prose">
        <Content />
      </div>

      <!-- Navigation -->
      <nav style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--border); display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
        {prevProject ? (
          <a href={`/projects/${prevProject.id}`} style="text-decoration: none;">
            <span class="lead" style="font-size: 11px; color: var(--grey);">← Previous</span>
            <span class="lead u-g" style="display: block; margin-top: 4px;">
              {prevProject.data.title}
            </span>
          </a>
        ) : <div />}
        {nextProject && (
          <a href={`/projects/${nextProject.id}`} style="text-align: right; text-decoration: none;">
            <span class="lead" style="font-size: 11px; color: var(--grey);">Next →</span>
            <span class="lead u-g" style="display: block; margin-top: 4px;">
              {nextProject.data.title}
            </span>
          </a>
        )}
      </nav>
    </div>

    {isTokenTracker && (
      <aside class="project-sidebar" id="project-sidebar">
        <div class="project-sidebar__sticky">
          <div class="widget-page" id="widget-page">
            <!-- SCREEN 0: Main stats -->
            <div class="widget-page__screen widget-page__screen--active" data-screen="0">
              <div class="widget-page__header">
                <span class="widget-page__icon">*</span>
                <span class="widget-page__label">Claude Token Tracker</span>
              </div>
              <div class="widget-page__hero">
                <div class="widget-page__big" id="wp-total">14.2M</div>
                <div class="widget-page__sub">lifetime tokens</div>
              </div>
              <div class="widget-page__stats">
                <div class="widget-page__stat">
                  <span class="widget-page__stat-label">Today</span>
                  <span class="widget-page__stat-value" id="wp-today">847.3K</span>
                </div>
                <div class="widget-page__stat">
                  <span class="widget-page__stat-label">Sessions</span>
                  <span class="widget-page__stat-value" id="wp-sessions">142</span>
                </div>
                <div class="widget-page__stat">
                  <span class="widget-page__stat-label">Cost</span>
                  <span class="widget-page__stat-value widget-page__stat-value--cost" id="wp-cost">~$142.80</span>
                </div>
              </div>
              <div class="widget-page__chart">
                <div class="widget-page__chart-label" id="wp-chart-label">7-day usage</div>
                <div class="widget-page__bars" id="wp-bars">
                  <div class="widget-page__bar" style="--h: 35%;"><span>M</span></div>
                  <div class="widget-page__bar" style="--h: 62%;"><span>T</span></div>
                  <div class="widget-page__bar" style="--h: 48%;"><span>W</span></div>
                  <div class="widget-page__bar widget-page__bar--peak" style="--h: 85%;"><span>T</span></div>
                  <div class="widget-page__bar" style="--h: 71%;"><span>F</span></div>
                  <div class="widget-page__bar" style="--h: 40%;"><span>S</span></div>
                  <div class="widget-page__bar widget-page__bar--today" style="--h: 55%;"><span>S</span></div>
                </div>
              </div>
              <div class="widget-page__models">
                <div class="widget-page__model-row">
                  <span class="widget-page__model-dot" style="background: #ff9500;"></span>
                  <span class="widget-page__model-name">Opus</span>
                  <span class="widget-page__model-val" id="wp-opus">8.4M</span>
                </div>
                <div class="widget-page__model-row">
                  <span class="widget-page__model-dot" style="background: #007aff;"></span>
                  <span class="widget-page__model-name">Sonnet</span>
                  <span class="widget-page__model-val" id="wp-sonnet">4.1M</span>
                </div>
                <div class="widget-page__model-row">
                  <span class="widget-page__model-dot" style="background: #34c759;"></span>
                  <span class="widget-page__model-name">Haiku</span>
                  <span class="widget-page__model-val" id="wp-haiku">1.7M</span>
                </div>
              </div>
              <div class="widget-page__budget">
                <div class="widget-page__budget-header">
                  <span class="widget-page__budget-label">Daily budget</span>
                  <span class="widget-page__budget-pct" id="wp-budget-pct">67%</span>
                </div>
                <div class="widget-page__budget-track">
                  <div class="widget-page__budget-fill" id="wp-budget-fill" style="width: 67%;"></div>
                </div>
              </div>
            </div>

            <!-- SCREEN 1: Settings -->
            <div class="widget-page__screen" data-screen="1">
              <div class="widget-page__header">
                <span class="widget-page__icon">&#9881;</span>
                <span class="widget-page__label">Settings</span>
              </div>
              <div class="wp-settings">
                <div class="wp-settings__section">
                  <div class="wp-settings__section-title">GENERAL</div>
                  <div class="wp-settings__row">
                    <span class="wp-settings__row-label">Always on top</span>
                    <span class="wp-settings__toggle wp-settings__toggle--on" id="ws-aot"></span>
                  </div>
                  <div class="wp-settings__row">
                    <span class="wp-settings__row-label">Show on all spaces</span>
                    <span class="wp-settings__toggle wp-settings__toggle--on"></span>
                  </div>
                  <div class="wp-settings__row">
                    <span class="wp-settings__row-label">Launch at login</span>
                    <span class="wp-settings__toggle"></span>
                  </div>
                </div>
                <div class="wp-settings__section">
                  <div class="wp-settings__section-title">APPEARANCE</div>
                  <div class="wp-settings__row">
                    <span class="wp-settings__row-label">Widget opacity</span>
                    <div class="wp-settings__slider">
                      <div class="wp-settings__slider-track">
                        <div class="wp-settings__slider-fill" id="ws-opacity" style="width: 85%;"></div>
                      </div>
                      <span class="wp-settings__slider-val">85%</span>
                    </div>
                  </div>
                  <div class="wp-settings__row">
                    <span class="wp-settings__row-label">Cost estimate</span>
                    <span class="wp-settings__toggle wp-settings__toggle--on"></span>
                  </div>
                  <div class="wp-settings__row">
                    <span class="wp-settings__row-label">Model breakdown</span>
                    <span class="wp-settings__toggle wp-settings__toggle--on"></span>
                  </div>
                </div>
                <div class="wp-settings__section">
                  <div class="wp-settings__section-title">BUDGET & ALERTS</div>
                  <div class="wp-settings__row">
                    <span class="wp-settings__row-label">Daily budget</span>
                    <span class="wp-settings__val">2,000,000</span>
                  </div>
                  <div class="wp-settings__row">
                    <span class="wp-settings__row-label">Warning at</span>
                    <span class="wp-settings__val">80%</span>
                  </div>
                  <div class="wp-settings__row">
                    <span class="wp-settings__row-label">Notifications</span>
                    <span class="wp-settings__toggle wp-settings__toggle--on"></span>
                  </div>
                </div>
                <div class="wp-settings__section">
                  <div class="wp-settings__section-title">DATA</div>
                  <div class="wp-settings__row">
                    <span class="wp-settings__row-label">Refresh interval</span>
                    <span class="wp-settings__val">10s</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- SCREEN 2: iCloud Sync -->
            <div class="widget-page__screen" data-screen="2">
              <div class="widget-page__header">
                <span class="widget-page__icon" style="color: rgba(0, 122, 255, 0.8);">&#9729;</span>
                <span class="widget-page__label">iCloud Sync</span>
              </div>
              <div class="wp-sync">
                <div class="wp-sync__status">
                  <div class="wp-sync__status-icon">&#10003;</div>
                  <div class="wp-sync__status-text">Synced</div>
                  <div class="wp-sync__status-sub">Last sync 12s ago</div>
                </div>
                <div class="wp-sync__machines">
                  <div class="wp-sync__section-title">DEVICES</div>
                  <div class="wp-sync__machine">
                    <div class="wp-sync__machine-icon">&#9633;</div>
                    <div class="wp-sync__machine-info">
                      <div class="wp-sync__machine-name">MacBook Pro</div>
                      <div class="wp-sync__machine-detail">8.4M tokens · Updated now</div>
                    </div>
                    <div class="wp-sync__machine-dot wp-sync__machine-dot--active"></div>
                  </div>
                  <div class="wp-sync__machine">
                    <div class="wp-sync__machine-icon">&#9633;</div>
                    <div class="wp-sync__machine-info">
                      <div class="wp-sync__machine-name">Mac Mini M2</div>
                      <div class="wp-sync__machine-detail">5.8M tokens · 3m ago</div>
                    </div>
                    <div class="wp-sync__machine-dot wp-sync__machine-dot--active"></div>
                  </div>
                </div>
                <div class="wp-sync__totals">
                  <div class="wp-sync__section-title">COMBINED</div>
                  <div class="wp-sync__total-row">
                    <span>Total tokens</span>
                    <span class="wp-sync__total-val">14.2M</span>
                  </div>
                  <div class="wp-sync__total-row">
                    <span>Total cost</span>
                    <span class="wp-sync__total-val wp-sync__total-val--cost">~$142.80</span>
                  </div>
                </div>
                <div class="wp-sync__encrypt">
                  <span class="wp-sync__encrypt-icon">&#128274;</span>
                  <span class="wp-sync__encrypt-text">End-to-end encrypted via iCloud Drive</span>
                </div>
              </div>
            </div>

            <!-- SCREEN 3: Discord Presence -->
            <div class="widget-page__screen" data-screen="3">
              <div class="widget-page__header">
                <span class="widget-page__icon" style="color: rgba(88, 101, 242, 0.9);">&#9673;</span>
                <span class="widget-page__label">Discord Rich Presence</span>
              </div>
              <div class="wp-discord">
                <div class="wp-discord__preview">
                  <div class="wp-discord__card">
                    <div class="wp-discord__card-header">PLAYING A GAME</div>
                    <div class="wp-discord__card-body">
                      <div class="wp-discord__card-icon">
                        <span>*</span>
                      </div>
                      <div class="wp-discord__card-info">
                        <div class="wp-discord__card-name">Claude Code</div>
                        <div class="wp-discord__card-detail" id="wp-discord-detail">Lifetime: 14.2M tokens</div>
                        <div class="wp-discord__card-detail" id="wp-discord-state">Today: 847.3K | Opus</div>
                        <div class="wp-discord__card-elapsed" id="wp-discord-time">02:34:17 elapsed</div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="wp-discord__info">
                  <div class="wp-settings__section">
                    <div class="wp-settings__section-title">STATUS</div>
                    <div class="wp-settings__row">
                      <span class="wp-settings__row-label">Rich Presence</span>
                      <span class="wp-settings__toggle wp-settings__toggle--on"></span>
                    </div>
                    <div class="wp-discord__hint">Shows token stats in your Discord profile. Connects via local IPC — no auth needed.</div>
                  </div>
                  <div class="wp-settings__section">
                    <div class="wp-settings__section-title">DISPLAYS</div>
                    <div class="wp-settings__row">
                      <span class="wp-settings__row-label">Lifetime tokens</span>
                      <span class="wp-settings__toggle wp-settings__toggle--on"></span>
                    </div>
                    <div class="wp-settings__row">
                      <span class="wp-settings__row-label">Daily tokens</span>
                      <span class="wp-settings__toggle wp-settings__toggle--on"></span>
                    </div>
                    <div class="wp-settings__row">
                      <span class="wp-settings__row-label">Top model</span>
                      <span class="wp-settings__toggle wp-settings__toggle--on"></span>
                    </div>
                  </div>
                </div>
              </div>
            </div>

          </div>
          <div class="widget-page__scroll-hint lead">( Scroll )</div>
        </div>
      </aside>
    )}

    {isFuel && (
      <aside class="project-sidebar" id="project-sidebar">
        <div class="project-sidebar__sticky">
          <div class="fuel-phone" id="fuel-phone">
            <div class="fuel-phone__notch"></div>

            <!-- SCREEN 0: Dashboard -->
            <div class="fuel-screen fuel-screen--active" data-screen="0">
              <div class="fuel-dash">
                <div class="fuel-dash__nav">
                  <span class="fuel-dash__nav-btn">‹</span>
                  <span class="fuel-dash__nav-title">Today</span>
                  <span class="fuel-dash__add-btn">+</span>
                </div>

                <div class="fuel-card">
                  <div class="fuel-dash__ring-wrap">
                    <svg class="fuel-dash__ring" viewBox="0 0 140 140">
                      <circle cx="70" cy="70" r="58" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="14"/>
                      <circle cx="70" cy="70" r="58" fill="none" stroke="#4DCC66" stroke-width="14"
                        stroke-dasharray="364" stroke-dashoffset="143" stroke-linecap="round"
                        transform="rotate(-90 70 70)" id="fuel-ring" class="fuel-dash__ring-fill"/>
                    </svg>
                    <div class="fuel-dash__ring-inner">
                      <div class="fuel-dash__ring-cal" id="fuel-cal-left">784</div>
                      <div class="fuel-dash__ring-label">remaining</div>
                      <div class="fuel-dash__ring-unit">cal</div>
                    </div>
                  </div>
                  <div class="fuel-dash__stats">
                    <div class="fuel-dash__stat">
                      <div class="fuel-dash__stat-val fuel-dash__stat-val--green" id="fuel-eaten">1,216</div>
                      <div class="fuel-dash__stat-label">Eaten</div>
                    </div>
                    <div class="fuel-dash__stat">
                      <div class="fuel-dash__stat-val fuel-dash__stat-val--primary" id="fuel-remaining-stat">784</div>
                      <div class="fuel-dash__stat-label">Remaining</div>
                    </div>
                    <div class="fuel-dash__stat">
                      <div class="fuel-dash__stat-val fuel-dash__stat-val--secondary">2,000</div>
                      <div class="fuel-dash__stat-label">Target</div>
                    </div>
                  </div>
                </div>

                <div class="fuel-card">
                  <div class="fuel-section-header">
                    <svg class="fuel-section-header__svg" width="14" height="14" viewBox="0 0 24 24" fill="rgba(255,255,255,0.4)"><path d="M11 2v20c-5.07-.5-9-4.79-9-10s3.93-9.5 9-10zm2.03 0v8.99H22c-.47-4.74-4.24-8.52-8.97-8.99zm0 11.01V22c4.74-.47 8.5-4.25 8.97-8.99h-8.97z"/></svg>
                    <span class="fuel-section-header__title">Macros</span>
                  </div>
                  <div class="fuel-dash__macros">
                    <div class="fuel-macro">
                      <div class="fuel-macro__header">
                        <span class="fuel-macro__name">Protein</span>
                        <span class="fuel-macro__val fuel-macro__val--protein" id="fuel-protein">86 / 150g</span>
                      </div>
                      <div class="fuel-macro__track"><div class="fuel-macro__fill fuel-macro__fill--protein" id="fuel-protein-bar" style="width: 57%;"></div></div>
                    </div>
                    <div class="fuel-macro">
                      <div class="fuel-macro__header">
                        <span class="fuel-macro__name">Carbs</span>
                        <span class="fuel-macro__val fuel-macro__val--carbs" id="fuel-carbs">134 / 250g</span>
                      </div>
                      <div class="fuel-macro__track"><div class="fuel-macro__fill fuel-macro__fill--carbs" id="fuel-carbs-bar" style="width: 54%;"></div></div>
                    </div>
                    <div class="fuel-macro">
                      <div class="fuel-macro__header">
                        <span class="fuel-macro__name">Fat</span>
                        <span class="fuel-macro__val fuel-macro__val--fat" id="fuel-fat">42 / 70g</span>
                      </div>
                      <div class="fuel-macro__track"><div class="fuel-macro__fill fuel-macro__fill--fat" id="fuel-fat-bar" style="width: 60%;"></div></div>
                    </div>
                    <div class="fuel-macro-split">
                      <div class="fuel-macro-split__seg" style="width:33%;background:#40CCFF;"></div>
                      <div class="fuel-macro-split__seg" style="width:41%;background:#FF8C33;"></div>
                      <div class="fuel-macro-split__seg" style="width:26%;background:#9959E6;"></div>
                    </div>
                  </div>
                </div>

                <div class="fuel-card">
                  <div class="fuel-section-header" style="margin-bottom:6px;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="#4DA6FF"><path d="M12 2c-5.33 8.33-8 12.67-8 16 0 4.42 3.58 8 8 8s8-3.58 8-8c0-3.33-2.67-7.67-8-16z"/></svg>
                    <span class="fuel-section-header__title">Water</span>
                    <span style="margin-left:auto;" class="fuel-water-count">5/8</span>
                  </div>
                  <div class="fuel-dash__water-drops">
                    <svg class="fuel-drop fuel-drop--filled" viewBox="0 0 24 24"><path d="M12 2c-5.33 8.33-8 12.67-8 16 0 4.42 3.58 8 8 8s8-3.58 8-8c0-3.33-2.67-7.67-8-16z"/></svg>
                    <svg class="fuel-drop fuel-drop--filled" viewBox="0 0 24 24"><path d="M12 2c-5.33 8.33-8 12.67-8 16 0 4.42 3.58 8 8 8s8-3.58 8-8c0-3.33-2.67-7.67-8-16z"/></svg>
                    <svg class="fuel-drop fuel-drop--filled" viewBox="0 0 24 24"><path d="M12 2c-5.33 8.33-8 12.67-8 16 0 4.42 3.58 8 8 8s8-3.58 8-8c0-3.33-2.67-7.67-8-16z"/></svg>
                    <svg class="fuel-drop fuel-drop--filled" viewBox="0 0 24 24"><path d="M12 2c-5.33 8.33-8 12.67-8 16 0 4.42 3.58 8 8 8s8-3.58 8-8c0-3.33-2.67-7.67-8-16z"/></svg>
                    <svg class="fuel-drop fuel-drop--filled" viewBox="0 0 24 24"><path d="M12 2c-5.33 8.33-8 12.67-8 16 0 4.42 3.58 8 8 8s8-3.58 8-8c0-3.33-2.67-7.67-8-16z"/></svg>
                    <svg class="fuel-drop" viewBox="0 0 24 24"><path d="M12 2c-5.33 8.33-8 12.67-8 16 0 4.42 3.58 8 8 8s8-3.58 8-8c0-3.33-2.67-7.67-8-16z"/></svg>
                    <svg class="fuel-drop" viewBox="0 0 24 24"><path d="M12 2c-5.33 8.33-8 12.67-8 16 0 4.42 3.58 8 8 8s8-3.58 8-8c0-3.33-2.67-7.67-8-16z"/></svg>
                    <svg class="fuel-drop" viewBox="0 0 24 24"><path d="M12 2c-5.33 8.33-8 12.67-8 16 0 4.42 3.58 8 8 8s8-3.58 8-8c0-3.33-2.67-7.67-8-16z"/></svg>
                  </div>
                  <div class="fuel-water-bar"><div class="fuel-water-bar__fill" style="width:62.5%;"></div></div>
                </div>
              </div>
            </div>

            <!-- SCREEN 1: AI Input — matches AddFoodSheet > NLPInputView > ParsedFoodConfirmView -->
            <div class="fuel-screen" data-screen="1">
              <div class="fuel-ai">
                <div class="fuel-ai__navbar">
                  <span class="fuel-ai__navbar-btn">Cancel</span>
                  <span class="fuel-ai__navbar-title">Add Food</span>
                  <span></span>
                </div>

                <div class="fuel-card">
                  <div class="fuel-ai__icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
                      <path d="M12 2L13.09 8.26L18 6L14.74 10.91L21 12L14.74 13.09L18 18L13.09 15.74L12 22L10.91 15.74L6 18L9.26 13.09L3 12L9.26 10.91L6 6L10.91 8.26L12 2Z" fill="#4DCC66"/>
                    </svg>
                  </div>
                  <div class="fuel-ai__heading">Describe what you ate</div>
                  <div class="fuel-ai__subheading">AI will estimate the nutrition info</div>

                  <div class="fuel-input__field" id="fuel-input-field">
                    <span class="fuel-input__cursor">|</span>
                  </div>

                  <div class="fuel-ai__examples">
                    <span class="fuel-ai__chip">2 eggs and toast</span>
                    <span class="fuel-ai__chip">chicken caesar salad</span>
                    <span class="fuel-ai__chip">grande latte with oat milk</span>
                  </div>

                  <div class="fuel-ai__btn">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" style="flex-shrink:0;">
                      <path d="M12 2L13.09 8.26L18 6L14.74 10.91L21 12L14.74 13.09L18 18L13.09 15.74L12 22L10.91 15.74L6 18L9.26 13.09L3 12L9.26 10.91L6 6L10.91 8.26L12 2Z" fill="white"/>
                    </svg>
                    Parse Food
                  </div>
                </div>

                <div class="fuel-input__result" id="fuel-parse-result">
                  <div class="fuel-input__parsing" id="fuel-parsing">
                    <span class="fuel-input__spinner"></span>
                    <span>Analyzing with AI...</span>
                  </div>
                  <div class="fuel-input__foods" id="fuel-foods" style="display:none;">
                    <div class="fuel-ai__confirm-header">
                      <div class="fuel-ai__confirm-count">4 items found</div>
                      <div class="fuel-ai__confirm-cal">376 cal total</div>
                    </div>
                    <div class="fuel-card fuel-ai__food-card">
                      <div class="fuel-ai__food-row">

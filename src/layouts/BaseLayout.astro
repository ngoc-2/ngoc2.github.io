---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Steven Nguyen — Developer & AI Builder', description = 'Developer, AI systems builder, neuroscience student at BYU.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script is:inline>
    (function() {
      var s = localStorage.getItem('theme');
      if (s === 'dark' || (!s && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
</head>
<body>
  <!-- Preloader -->
  <div class="preloader" id="preloader">
    <div class="preloader__wrapper">
      <div class="preloader__bar-line">
        <span class="preloader__bracket">[</span><span class="preloader__fill" id="preloader-fill"></span><span class="preloader__bracket">]</span>
      </div>
      <div class="preloader__pct" id="preloader-pct">0%</div>
    </div>
  </div>

  <!-- Custom Cursor -->
  <div class="cursor" id="cursor">
    <div class="cursor__dot"></div>
  </div>

  <!-- Header -->
  <header class="site-header" id="site-header">
    <div>
      <a class="site-header__brand" href="/">
        <span>Steven Nguyen</span>
      </a>
    </div>
    <div>
      <nav>
        <ul class="site-nav__list">
          <li><a href="/photos" class="site-nav__link">Photos</a></li>
          <li><a href="/#work" class="site-nav__link">Work</a></li>
          <li><a href="/#about" class="site-nav__link">About</a></li>
          <li><button class="site-nav__link theme-toggle" onclick="toggleTheme()">Dark</button></li>
        </ul>
      </nav>
      <button class="menu-toggle" id="menu-toggle">Menu</button>
    </div>
  </header>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu">
    <a href="/" onclick="closeMobileMenu()">Home</a>
    <a href="/#work" onclick="closeMobileMenu()">Work</a>
    <a href="/photos" onclick="closeMobileMenu()">Photos</a>
    <a href="/#about" onclick="closeMobileMenu()">About</a>
    <a href="/#contact" onclick="closeMobileMenu()">Contact</a>
    <button class="theme-toggle" onclick="toggleTheme()" style="background:none;border:none;color:inherit;font-family:var(--font-display);font-size:2.5rem;text-transform:uppercase;letter-spacing:-0.01em;cursor:pointer;">Dark</button>
  </div>

  <main>
    <slot />
  </main>

  <!-- GSAP + ScrollTrigger + Lenis -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>
  <script is:inline src="https://unpkg.com/lenis@1.1.18/dist/lenis.min.js"></script>

  <script is:inline>
    // ═══════════════════════════════════════
    // LENIS SMOOTH SCROLL
    // ═══════════════════════════════════════
    const isMobile = window.matchMedia('(max-width: 768px)').matches;
    const lenis = new Lenis({
      duration: 1.2,
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smoothWheel: !isMobile,
      smoothTouch: false,
    });

    if (!isMobile) {
      lenis.on('scroll', ScrollTrigger.update);
      gsap.ticker.add((time) => lenis.raf(time * 1000));
      gsap.ticker.lagSmoothing(0);
    }

    // ═══════════════════════════════════════
    // PRELOADER — ASCII PROGRESS BAR
    // ═══════════════════════════════════════
    (function() {
      const fillEl = document.getElementById('preloader-fill');
      const pctEl = document.getElementById('preloader-pct');
      const preloader = document.getElementById('preloader');
      const barWidth = 30;

      function render(progress) {
        const filled = Math.round((progress / 100) * barWidth);
        fillEl.textContent = '█'.repeat(filled) + '░'.repeat(barWidth - filled);
        pctEl.textContent = Math.round(progress) + '%';
      }

      render(0);

      window.addEventListener('load', () => {
        render(100);
        gsap.to(preloader, {
          opacity: 0,
          duration: 0.4,
          delay: 0.1,
          ease: 'power2.inOut',
          onComplete: () => {
            preloader.style.display = 'none';
            lenis.start();
            animateHero();
          }
        });
      });
    })();

    // ═══════════════════════════════════════
    // CUSTOM CURSOR
    // ═══════════════════════════════════════
    const cursor = document.getElementById('cursor');
    if (cursor && window.matchMedia('(pointer: fine)').matches) {
      let cx = 0, cy = 0, tx = 0, ty = 0;

      document.addEventListener('mousemove', (e) => {
        tx = e.clientX;
        ty = e.clientY;
      });

      function updateCursor() {
        cx += (tx - cx) * 0.15;
        cy += (ty - cy) * 0.15;
        cursor.style.transform = `translate3d(${cx}px, ${cy}px, 0)`;
        requestAnimationFrame(updateCursor);
      }
      updateCursor();
      cursor.style.opacity = '1';

      // Scale up on links/buttons
      document.querySelectorAll('a, button, .gallery-item').forEach(el => {
        el.addEventListener('mouseenter', () => cursor.classList.add('cursor--active'));
        el.addEventListener('mouseleave', () => cursor.classList.remove('cursor--active'));
      });
    }

    // ═══════════════════════════════════════
    // HERO ANIMATION — Staggered text reveal
    // ═══════════════════════════════════════
    function animateHero() {
      gsap.fromTo('.hero-slideshow', { scale: 0.9, opacity: 0 }, { scale: 1, opacity: 1, duration: 1.4, ease: 'power4.out' });
      gsap.fromTo('.hero-overlap__text .display', { y: 60, opacity: 0 }, { y: 0, opacity: 1, duration: 1.2, stagger: 0.15, delay: 0.3, ease: 'power4.out' });

      // Header — slide down
      gsap.fromTo('#site-header', {
        y: -40,
        opacity: 0,
      }, {
        y: 0,
        opacity: 1,
        duration: 1,
        delay: 0.8,
        ease: 'power3.out',
      });
    }

    // ═══════════════════════════════════════
    // SCROLL ANIMATIONS — GSAP ScrollTrigger
    // ═══════════════════════════════════════
    gsap.registerPlugin(ScrollTrigger);

    // Quote text — line-by-line reveal with parallax
    document.querySelectorAll('.quote-text').forEach(quote => {
      // Wrap each line in a span for animation
      const html = quote.innerHTML;
      const lines = html.split('<br>').map(l => l.trim()).filter(Boolean);
      quote.innerHTML = lines.map(l =>
        `<div class="quote-line" style="overflow:hidden;"><span class="quote-line__inner" style="display:block;">${l}</span></div>`
      ).join('');

      gsap.fromTo(quote.querySelectorAll('.quote-line__inner'), {
        y: '110%',
        rotateX: -20,
      }, {
        y: '0%',
        rotateX: 0,
        duration: 1.2,
        stagger: 0.1,
        ease: 'power4.out',
        scrollTrigger: {
          trigger: quote,
          start: 'top 80%',
          toggleActions: 'play none none none',
        }
      });
    });

    // Quote attribution — fade in
    document.querySelectorAll('.quote-attribution').forEach(attr => {
      gsap.fromTo(attr, {
        opacity: 0,
        y: 30,
      }, {
        opacity: 1,
        y: 0,
        duration: 1,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: attr,
          start: 'top 85%',
        }
      });
    });

    // Photo section — scale in
    document.querySelectorAll('.js-in:not(.hero-row)').forEach(el => {
      // Skip hero elements (animated separately)
      if (el.closest('.home-hero')) return;

      gsap.fromTo(el, {
        y: isMobile ? 20 : 60,
        opacity: 0,
      }, {
        y: 0,
        opacity: 1,
        duration: isMobile ? 0.6 : 1,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 90%',
          toggleActions: 'play none none none',
        }
      });
    });

    // Hero title — split apart on scroll
    var heroTexts = document.querySelectorAll('.hero-overlap__text .display');
    if (heroTexts.length >= 2) {
      gsap.to(heroTexts[0], { y: -120, ease: 'none', scrollTrigger: { trigger: '.home-hero', start: 'top top', end: 'bottom top', scrub: 1 } });
      gsap.to(heroTexts[1], { y: 120, ease: 'none', scrollTrigger: { trigger: '.home-hero', start: 'top top', end: 'bottom top', scrub: 1 } });
      gsap.to('.hero-slideshow', { scale: 0.92, ease: 'none', scrollTrigger: { trigger: '.home-hero', start: 'top top', end: 'bottom top', scrub: 1 } });
    }

    // Project cards — stagger slide up
    document.querySelectorAll('.project-card').forEach((card, i) => {
      gsap.fromTo(card, {
        y: isMobile ? 20 : 80,
        opacity: 0,
      }, {
        y: 0,
        opacity: 1,
        duration: isMobile ? 0.5 : 1,
        delay: isMobile ? i * 0.03 : i * 0.08,
        ease: 'power4.out',
        scrollTrigger: {
          trigger: card,
          start: 'top 95%',
        }
      });
    });

    // Gallery images — parallax on scroll
    document.querySelectorAll('.gallery-item img').forEach(img => {
      gsap.fromTo(img, {
        scale: 1.15,
      }, {
        scale: 1,
        ease: 'none',
        scrollTrigger: {
          trigger: img.closest('.gallery-section'),
          start: 'top bottom',
          end: 'bottom top',
          scrub: 1.5,
        }
      });
    });

    // Display headings — parallax speed difference
    document.querySelectorAll('.display--2').forEach(heading => {
      gsap.fromTo(heading, {
        y: 40,
        opacity: 0,
      }, {
        y: 0,
        opacity: 1,
        duration: 1.2,
        ease: 'power4.out',
        scrollTrigger: {
          trigger: heading,
          start: 'top 85%',
        }
      });
    });

    // About section text — paragraph stagger
    document.querySelectorAll('#about p').forEach((p, i) => {
      gsap.fromTo(p, {
        y: 40,
        opacity: 0,
      }, {
        y: 0,
        opacity: 1,
        duration: 0.9,
        delay: i * 0.1,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: p,
          start: 'top 88%',
        }
      });
    });

    // Footer outro — slide up
    document.querySelectorAll('.site-footer__outro > div').forEach((col, i) => {
      gsap.fromTo(col, {
        y: 40,
        opacity: 0,
      }, {
        y: 0,
        opacity: 1,
        duration: 0.8,
        delay: i * 0.12,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.site-footer__outro',
          start: 'top 90%',
        }
      });
    });

    // Build section — browser mockup builds up, features stagger
    var buildBrowser = document.querySelector('.build-browser');
    if (buildBrowser) {
      // Browser slides in from left
      gsap.fromTo(buildBrowser, {
        x: -60,
        opacity: 0,
      }, {
        x: 0,
        opacity: 1,
        duration: 1.2,
        ease: 'power4.out',
        scrollTrigger: {
          trigger: buildBrowser,
          start: 'top 85%',
        }
      });

      // Wireframe elements build sequentially
      var wireEls = buildBrowser.querySelectorAll('.build-wire__nav, .build-wire__line, .build-wire__cta, .build-wire__card');
      wireEls.forEach(function(el, i) {
        gsap.fromTo(el, {
          opacity: 0,
          y: 8,
        }, {
          opacity: 1,
          y: 0,
          duration: 0.5,
          delay: 0.4 + i * 0.08,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: buildBrowser,
            start: 'top 85%',
          }
        });
      });

      // Lighthouse scores count up
      var scoreEls = buildBrowser.querySelectorAll('.build-browser__stat-val--green');
      scoreEls.forEach(function(el) {
        var target = 100;
        var obj = { val: 0 };
        gsap.to(obj, {
          val: target,
          duration: 1.5,
          delay: 0.8,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: buildBrowser,
            start: 'top 85%',
          },
          onUpdate: function() {
            el.textContent = Math.round(obj.val);
          }
        });
      });

      // Load time counts
      var loadEl = buildBrowser.querySelector('.build-browser__stat-val:not(.build-browser__stat-val--green)');
      if (loadEl) {
        var loadObj = { val: 0 };
        gsap.to(loadObj, {
          val: 0.4,
          duration: 1.5,
          delay: 0.8,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: buildBrowser,
            start: 'top 85%',
          },
          onUpdate: function() {
            loadEl.textContent = loadObj.val.toFixed(1) + 's';
          }
        });
      }
    }

    // Build features — stagger from right
    document.querySelectorAll('.build-section__feature').forEach(function(feat, i) {
      gsap.fromTo(feat, {
        x: 40,
        opacity: 0,
      }, {
        x: 0,
        opacity: 1,
        duration: 0.8,
        delay: i * 0.12,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: feat,
          start: 'top 90%',
        }
      });
    });

    // Contact cards — stagger
    document.querySelectorAll('.contact-card').forEach(function(card, i) {
      gsap.fromTo(card, {
        y: 30,
        opacity: 0,
      }, {
        y: 0,
        opacity: 1,
        duration: 0.7,
        delay: i * 0.08,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: card,
          start: 'top 92%',
        }
      });
    });

    // Photo grid items — stagger reveal
    document.querySelectorAll('.photo-grid__item').forEach((item, i) => {
      gsap.fromTo(item, {
        y: 60,
        opacity: 0,
        scale: 0.95,
      }, {
        y: 0,
        opacity: 1,
        scale: 1,
        duration: 0.8,
        delay: (i % 6) * 0.08,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: item,
          start: 'top 92%',
        }
      });
    });

    // ═══════════════════════════════════════
    // MAGNETIC HOVER on nav links
    // ═══════════════════════════════════════
    document.querySelectorAll('.site-nav__link, .site-header__brand').forEach(link => {
      link.addEventListener('mousemove', (e) => {
        const rect = link.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        gsap.to(link, { x: x * 0.3, y: y * 0.3, duration: 0.3, ease: 'power2.out' });
      });
      link.addEventListener('mouseleave', () => {
        gsap.to(link, { x: 0, y: 0, duration: 0.5, ease: 'elastic.out(1, 0.5)' });
      });
    });

    // ═══════════════════════════════════════
    // MOBILE MENU
    // ═══════════════════════════════════════
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');

    menuToggle?.addEventListener('click', () => {
      const isOpen = mobileMenu?.classList.toggle('open');
      menuToggle.textContent = isOpen ? 'Close' : 'Menu';
      if (isOpen) lenis.stop(); else lenis.start();
    });

    window.closeMobileMenu = function() {
      mobileMenu?.classList.remove('open');
      if (menuToggle) menuToggle.textContent = 'Menu';
      lenis.start();
    };

    // ═══════════════════════════════════════
    // THEME TOGGLE
    // ═══════════════════════════════════════
    function updateToggleText() {
      var isDark = document.documentElement.classList.contains('dark');
      document.querySelectorAll('.theme-toggle').forEach(function(btn) {
        btn.textContent = isDark ? 'Light' : 'Dark';
      });
    }
    updateToggleText();

    window.toggleTheme = function() {
      document.documentElement.classList.toggle('dark');
      var isDark = document.documentElement.classList.contains('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateToggleText();
    };
  </script>
</body>
</html>
